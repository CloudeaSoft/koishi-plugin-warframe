{
  "compilerOptions": {
    "incremental": true,
    "composite": true,
    "target": "es2022",
    "jsx": "react-jsx",
    "jsxImportSource": "@satorijs/element",
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "mocha"],
    "strictNullChecks": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "lib",
    "outFile": "lib/index.d.ts",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "src/**/*.json"]
}
